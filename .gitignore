# =============================================================================
# .gitignore  -  NeuSym-HLS
# =============================================================================

# ── Dataset (downloaded automatically by torchvision) ─────────────────────────
data/

# ── Model checkpoints ─────────────────────────────────────────────────────────
checkpoints/
*.pt
*.pth

# ── Trace files (large numpy arrays, regenerated by Module 1) ─────────────────
traces/
*.npy

# ── Symbolic regression outputs (regenerated by Module 2) ─────────────────────
sr_results/
*.pkl

# ── HLS generated code (regenerated by Module 3) ──────────────────────────────
hls_output/

# ── Evaluation results / charts (regenerated by Module 5) ─────────────────────
eval_results/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ───────────────────────────────────────────────────────
venv/
env/
.env/
.venv/

# ── Jupyter notebooks (if any) ────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── OS files ──────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE files ─────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Julia / PySR runtime files ────────────────────────────────────────────────
*.jl.bak
sr_search.jl
hall_of_fame*.csv

# ── Vitis HLS project folders (large, generated by synth.tcl) ─────────────────
hybrid_neusym_*/
hls4ml_prj/
*.log
*.rpt
